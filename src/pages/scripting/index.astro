---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/site';

// Render the canonical 5250script.md reference that lives in the main repo.
// Imported directly so it's processed by Astro's markdown pipeline (syntax
// highlighting via Shiki, defined in astro.config.mjs).
import { Content, getHeadings } from '../../content/docs/5250script.md';

// Table-of-contents from top-level headings (## only).
const toc = getHeadings().filter(h => h.depth === 2);
---

<Base
  title="5250Script reference"
  description="The 5250Script scripting language for automating TN5250 sessions in 5250ng."
>
  <section class="section">
    <div class="container">
      <div class="section-eyebrow">Documentation</div>
      <h1>5250Script reference</h1>
      <p class="section-lead">
        A line-based scripting language for automating TN5250 sessions.
        Inspired by Unix <code>expect</code> — one command per line,
        ALL-CAPS keywords, with control flow and error handlers.
      </p>

      <div class="btn-row">
        <a class="btn" href={`${SITE.github}/blob/main/docs/5250script.md`} rel="noopener">
          View source on GitHub
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="docs-grid">
        {toc.length > 0 && (
          <aside class="docs-toc" aria-label="On this page">
            <div class="section-eyebrow">On this page</div>
            <ul>
              {toc.map(h => (
                <li><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ul>
          </aside>
        )}

        <article class="prose">
          <Content />
        </article>
      </div>
    </div>
  </section>
</Base>

<style>
  .docs-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .docs-grid { grid-template-columns: 1fr; }
    .docs-toc { order: 2; }
  }
  .docs-toc {
    position: sticky;
    top: 80px;
    font-size: 0.88rem;
  }
  .docs-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .docs-toc a {
    color: var(--text-muted);
    display: block;
    padding: 0.2rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.7rem;
    margin-left: -0.7rem;
  }
  .docs-toc a:hover {
    color: #fff;
    border-left-color: var(--amber);
  }
</style>
