{
    "id": "blue_terminal",
    "displayName": "Blue Terminal",
    "builtin": true,
    "description": "Cool blue phosphor display \u2014 inspired by later-generation IBM 3278 terminals.",
    "background": {
        "mode": "color",
        "color": "#000818",
        "imageLayout": "stretch",
        "imageOpacity": 1.0
    },
    "font": {
        "family": "IBM Plex Mono",
        "size": 14
    },
    "colors": {
        "black": "#000818",
        "green": "#33bbff",
        "white": "#ddeeff",
        "blue": "#2266cc",
        "red": "#ff4466",
        "cyan": "#66ddff",
        "pink": "#bb88ff",
        "yellow": "#aaddff",
        "cursor": "#33bbff"
    },
    "selection": {
        "background": "#4033bbff",
        "foreground": "#ffffff",
        "fieldIndicator": "#3033bbff"
    },
    "columnSeparator": {
        "enabled": false,
        "color": "#1a4466",
        "style": "solid"
    },
    "cursor": {
        "shape": "block",
        "blinkMs": 530
    },
    "crtEffect": {
        "enabled": true,
        "scanlineIntensity": 0.15,
        "phosphorBloom": 0.3,
        "glowRadius": 0.12,
        "curvature": 0.05
    },
    "globalBrightness": 1.0,
    "globalSaturation": 1.0,
    "hrule": {
        "color": "#33bbff"
    },
    "footer": {
        "kbdStateColor": "#aaddff",
        "systemNameColor": "#66ddff",
        "historyColor": "#ffaa33",
        "macroColor": "#ff4466",
        "coordinatesColor": "#33bbff"
    }
}
